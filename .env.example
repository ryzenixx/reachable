# Optional image override
# REACHABLE_IMAGE=ghcr.io/ryzenixx/reachable:latest

# Host ports
# API_PORT=8009
# FRONTEND_PORT=3000
# REVERB_PORT=8080

# Postgres credentials
# POSTGRES_DB=reachable
# POSTGRES_USER=reachable
# POSTGRES_PASSWORD=reachable

# Optional URL overrides (mostly for reverse proxy / custom domain)
# APP_URL=http://localhost:8009
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8009/api/v1
# NEXT_PUBLIC_REVERB_HOST=localhost
# NEXT_PUBLIC_REVERB_SCHEME=http
